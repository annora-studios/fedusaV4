<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:padding="20dp" android:layout_width="match_parent" android:layout_height="match_parent">
<TextView android:id="@+id/title" android:text="FEDUSA Congress 2026" android:textSize="28sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
<TextView android:id="@+id/status" android:text="Sign in to begin" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
<EditText android:id="@+id/username" android:hint="Username" android:layout_width="match_parent" android:layout_height="wrap_content"/>
<EditText android:id="@+id/password" android:hint="Password" android:inputType="textPassword" android:layout_width="match_parent" android:layout_height="wrap_content"/>
<Button android:id="@+id/login" android:text="Sign in" android:layout_width="match_parent" android:layout_height="wrap_content"/>
<RadioGroup android:id="@+id/mode" android:visibility="gone" android:orientation="horizontal" android:layout_marginTop="12dp" android:layout_width="match_parent" android:layout_height="wrap_content">
<RadioButton android:id="@+id/congressMode" android:checked="true" android:text="Congress" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
<RadioButton android:id="@+id/votingMode" android:text="Voting session" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
</RadioGroup>
<androidx.camera.view.PreviewView android:id="@+id/camera" android:visibility="gone" android:layout_marginTop="16dp" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
<EditText android:id="@+id/manualCode" android:visibility="gone" android:hint="Manual badge ID or QR value" android:layout_width="match_parent" android:layout_height="wrap_content"/>
<Button android:id="@+id/manual" android:visibility="gone" android:text="Manual override" android:layout_width="match_parent" android:layout_height="wrap_content"/>
<TextView android:id="@+id/result" android:textSize="22sp" android:textStyle="bold" android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
</LinearLayout>
